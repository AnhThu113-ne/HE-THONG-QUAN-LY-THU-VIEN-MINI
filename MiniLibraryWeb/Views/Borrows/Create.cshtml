@model MiniLibraryWeb.Models.ViewModels.BorrowRequestVM
@{
    ViewData["Title"] = "Lập Phiếu Mượn";
    ViewData["PageTitle"] = "Lập Phiếu Mượn Sách";
}

<div class="page-card" style="max-width: 600px; margin: 0 auto;">
    <div class="page-card-header">
        <div class="page-card-title">
            <i class="fa-solid fa-file-invoice" style="color: var(--primary);"></i>
            <span>Thông tin phiếu mượn sách</span>
        </div>
        <a asp-action="Index" class="btn-premium btn-premium-secondary">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
    </div>
    <div class="page-card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" style="color: var(--danger); font-size: 14px; margin-bottom: 16px;"></div>

            <div class="form-group-premium">
                <label asp-for="ReaderId" class="form-label-premium"></label>
                <select asp-for="ReaderId" class="form-control-premium" asp-items="@(new SelectList(Model.Readers, "Id", "Name"))">
                    <option value="">-- Chọn Độc giả --</option>
                </select>
                <span asp-validation-for="ReaderId" style="color: var(--danger); font-size: 12px; margin-top: 4px; display: block;"></span>
            </div>

            <div class="form-group-premium">
                <label asp-for="BookId" class="form-label-premium"></label>
                <select asp-for="BookId" class="form-control-premium">
                    <option value="">-- Chọn Sách --</option>
                    @if (Model.Books != null)
                    {
                        foreach (var book in Model.Books)
                        {
                            var isOutOfStock = book.Stock <= 0;
                            if (isOutOfStock)
                            {
                                <option value="@book.Id" disabled style="color: var(--text-muted);">
                                    @book.Title - Tác giả: @book.Author (ĐÃ HẾT SÁCH)
                                </option>
                            }
                            else
                            {
                                <option value="@book.Id">
                                    @book.Title - Tác giả: @book.Author (Còn tồn: @book.Stock)
                                </option>
                            }
                        }
                    }
                </select>
                <span asp-validation-for="BookId" style="color: var(--danger); font-size: 12px; margin-top: 4px; display: block;"></span>
            </div>

            <div class="form-group-premium">
                <label asp-for="DueDate" class="form-label-premium"></label>
                <input asp-for="DueDate" type="date" class="form-control-premium" value="@Model.DueDate.ToString("yyyy-MM-dd")" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="DueDate" style="color: var(--danger); font-size: 12px; margin-top: 4px; display: block;"></span>
            </div>

            <div style="display: flex; gap: 16px; margin-top: 32px;">
                <button type="submit" class="btn-premium btn-premium-primary" style="flex: 1;">
                    <i class="fa-solid fa-file-signature"></i> Lập phiếu mượn
                </button>
                <a asp-action="Index" class="btn-premium btn-premium-secondary" style="flex: 1;">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
