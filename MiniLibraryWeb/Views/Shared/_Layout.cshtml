@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Thư Viện Mini</title>
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MiniLibraryWeb.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-logo">
            <i class="fa-solid fa-book-open-reader"></i>
            <span>MiniLibrary<span>.</span></span>
        </div>
        <ul class="sidebar-menu">
            <li class="sidebar-item @(currentController == "Home" ? "active" : "")">
                <a asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-chart-line"></i>
                    <span>Bảng điều khiển</span>
                </a>
            </li>
            <li class="sidebar-item @(currentController == "Books" ? "active" : "")">
                <a asp-controller="Books" asp-action="Index">
                    <i class="fa-solid fa-book"></i>
                    <span>Quản lý Sách</span>
                </a>
            </li>
            <li class="sidebar-item @(currentController == "Readers" ? "active" : "")">
                <a asp-controller="Readers" asp-action="Index">
                    <i class="fa-solid fa-users"></i>
                    <span>Độc giả</span>
                </a>
            </li>
            <li class="sidebar-item @(currentController == "Borrows" ? "active" : "")">
                <a asp-controller="Borrows" asp-action="Index">
                    <i class="fa-solid fa-receipt"></i>
                    <span>Mượn / Trả Sách</span>
                </a>
            </li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="app-container">
        <header class="app-header">
            <div class="header-title">
                <h1>@(ViewData["PageTitle"] ?? "Thư Viện Mini")</h1>
            </div>
            <div class="header-meta">
                <i class="fa-regular fa-calendar-days"></i>
                <span>@DateTime.Now.ToString("dd/MM/yyyy")</span>
            </div>
        </header>

        <main class="app-content">
            <!-- Toast notification system -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert-premium alert-premium-success">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>@TempData["SuccessMessage"]</span>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert-premium alert-premium-danger">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>@TempData["ErrorMessage"]</span>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
