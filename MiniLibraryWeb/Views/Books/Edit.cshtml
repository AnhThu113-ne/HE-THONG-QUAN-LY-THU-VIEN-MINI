@model MiniLibraryWeb.Models.Entities.Book
@{
    ViewData["Title"] = "Sửa Thông Tin Sách";
    ViewData["PageTitle"] = "Sửa Thông Tin Sách";
}

<div class="page-card" style="max-width: 600px; margin: 0 auto;">
    <div class="page-card-header">
        <div class="page-card-title">
            <i class="fa-solid fa-pen-to-square" style="color: var(--primary);"></i>
            <span>Cập nhật thông tin sách</span>
        </div>
        <a asp-action="Index" class="btn-premium btn-premium-secondary">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
    </div>
    <div class="page-card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" style="color: var(--danger); font-size: 14px; margin-bottom: 16px;"></div>

            <div class="form-group-premium">
                <label asp-for="Title" class="form-label-premium"></label>
                <input asp-for="Title" class="form-control-premium" placeholder="Nhập tiêu đề sách..." />
                <span asp-validation-for="Title" style="color: var(--danger); font-size: 12px; margin-top: 4px; display: block;"></span>
            </div>

            <div class="form-group-premium">
                <label asp-for="Author" class="form-label-premium"></label>
                <input asp-for="Author" class="form-control-premium" placeholder="Nhập tên tác giả..." />
                <span asp-validation-for="Author" style="color: var(--danger); font-size: 12px; margin-top: 4px; display: block;"></span>
            </div>

            <div class="form-group-premium">
                <label asp-for="Category" class="form-label-premium"></label>
                <input asp-for="Category" class="form-control-premium" placeholder="Nhập thể loại..." />
                <span asp-validation-for="Category" style="color: var(--danger); font-size: 12px; margin-top: 4px; display: block;"></span>
            </div>

            <div class="form-group-premium">
                <label asp-for="PublishYear" class="form-label-premium"></label>
                <input asp-for="PublishYear" type="number" class="form-control-premium" placeholder="Năm xuất bản..." />
                <span asp-validation-for="PublishYear" style="color: var(--danger); font-size: 12px; margin-top: 4px; display: block;"></span>
            </div>

            <div class="form-group-premium">
                <label asp-for="Stock" class="form-label-premium"></label>
                <input asp-for="Stock" type="number" class="form-control-premium" placeholder="Số lượng trong kho..." />
                <span asp-validation-for="Stock" style="color: var(--danger); font-size: 12px; margin-top: 4px; display: block;"></span>
            </div>

            <div style="display: flex; gap: 16px; margin-top: 32px;">
                <button type="submit" class="btn-premium btn-premium-primary" style="flex: 1;">
                    <i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi
                </button>
                <a asp-action="Index" class="btn-premium btn-premium-secondary" style="flex: 1;">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
